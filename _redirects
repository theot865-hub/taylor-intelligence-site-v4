# Cloudflare Workers static-assets rewrites so the client-side router can render
# bare paths (200 = rewrite, URL stays put — no browser redirect).
# NOTE: rewrite to "/" NOT "/index.html". Cloudflare auto-redirects any
# request that resolves to /index.html back to / (a 307), which would strip the
# path before the router sees it and bounce every route to Home.
/card       /   200
/services   /   200
/approach   /   200
/contact    /   200
